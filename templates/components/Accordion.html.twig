{%- props multiple = false, disabled = false, value = [], dir = 'ltr', name = null, as = 'div' -%}

{%- set _hui_accordion_open_values = multiple ? value : value|slice(0, 1) -%}
{%- set _hui_accordion_multiple = multiple -%}
{%- set _hui_accordion_disabled = disabled -%}
{%- set _hui_accordion_name = name|default(hui_id('accordion')) -%}
<{{ as }}
    data-slot="accordion"
    dir="{{ dir }}"
    data-controller="hui-accordion"
    data-hui-accordion-multiple-value="{{ multiple ? 'true' : 'false' }}"
    data-hui-accordion-disabled-value="{{ disabled ? 'true' : 'false' }}"
    class="{{ hui('accordion').apply({}, attributes.render('class'))|tailwind_merge }}"
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</{{ as }}>
