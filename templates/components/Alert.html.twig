{%- props variant = 'default', as = 'div' -%}
{%- set style = hui('alert') -%}
<{{ as }}
    class="{{ style.apply({variant: variant}, attributes.render('class'))|tailwind_merge }}"
    {{ attributes.defaults({
        'data-slot': 'alert',
        role: 'alert',
    }) }}
>
    {%- block content %}{% endblock -%}
</{{ as }}>
