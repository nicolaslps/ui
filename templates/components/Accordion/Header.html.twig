{%- props as = 'h3' -%}
{%- set _hui_header_content -%}{% block content %}{% endblock %}{%- endset -%}
<summary
    class="{{ hui('accordion-trigger').apply({}, attributes.render('class'))|tailwind_merge }}"
    {{ attributes.defaults({
        'data-slot': 'accordion-header',
        'data-hui-accordion-target': 'trigger',
        'data-action': 'click->hui-accordion#guard keydown->hui-accordion#navigate',
        'data-state': _hui_accordion_item_open|default(false) ? 'open' : 'closed',
        id: _hui_accordion_item_header_id|default(false),
        'aria-disabled': _hui_accordion_item_disabled|default(false),
    }) }}
>
    <{{ as }} class="{{ hui('accordion-header').apply({}) }}">
        {{- _hui_header_content -}}
        {%- if 'data-slot="accordion-indicator"' not in _hui_header_content -%}
            <twig:ui:Accordion:Indicator />
        {%- endif -%}
    </{{ as }}>
</summary>
