{%- props as = 'div' -%}
<{{ as }}
    class="{{ hui('accordion-panel').apply({}, attributes.render('class'))|tailwind_merge }}"
    {{ attributes.defaults({
        'data-slot': 'accordion-panel',
        'data-hui-accordion-target': 'content',
        'data-state': _hui_accordion_item_open|default(false) ? 'open' : 'closed',
        role: 'region',
        'aria-labelledby': _hui_accordion_item_header_id|default(false),
    }) }}
>
    {%- block content %}{% endblock -%}
</{{ as }}>
