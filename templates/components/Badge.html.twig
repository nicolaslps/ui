{%- props variant = 'default', size = 'md', as = 'span' -%}
{%- set style = hui('badge') -%}
<{{ as }}
    class="{{ style.apply({variant: variant, size: size}, attributes.render('class'))|tailwind_merge }}"
    {{ attributes.defaults({
        'data-slot': 'badge',
    }) }}
>
    {%- block content %}{% endblock -%}
</{{ as }}>
